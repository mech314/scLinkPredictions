// nextflow.config

def BASELINE_SPLIT = "MONDO_HGNC"
def DEVICE = "3"
def MODEL = "transe"
def MONARCH_KG_PATH = "${projectDir}/data/MonarchKG/monarch-kg_edges.tsv"
def NODES = "MONDO:,HGNC:"
def RANDOM_SEEDS = "42,314,123,678,9484"
def SIMILARITIES_DIR = "${projectDir}/out/cosine_sim"

params {
    // Filter
    monarch_kg = "${MONARCH_KG_PATH}"
    nodes2filter = "${NODES}"
    filterOut = "${projectDir}/out/filtered_graphs"

    // Splits
    seeds="${RANDOM_SEEDS}"
    sim_dir="${SIMILARITIES_DIR}"
    baselineSplitsOut="${projectDir}/out/KG_split/${BASELINE_SPLIT}/baseline"
    augmentedSplitOut="${projectDir}/out/KG_split/${BASELINE_SPLIT}/augmented"

    // HPO
    graph = "${BASELINE_SPLIT}"
    device = "${DEVICE}"
    model = "${MODEL}"
    study_name = "${MODEL}_${BASELINE_SPLIT}"
    pykeenOut = "${projectDir}/out/PyKeenOut"
}